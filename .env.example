# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=sandbox
PAYPAL_CLIENT_SECRET=sandbox
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stable Server Action IDs across dev restarts (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Admin staging review (/admin/staging) — must match a signed-in Supabase user email
ADMIN_EMAIL=

# CJ Dropshipping (fulfillment disabled without CJ_API_KEY)
# Auth is apiKey-only: POST .../authentication/getAccessToken { "apiKey": "..." }
CJ_API_KEY=
# Optional: customer email fallback for createOrderV2 when auth user has no email
CJ_EMAIL=
# Optional: logistics profile for createOrderV2 (default: PostNL)
CJ_LOGISTIC_NAME=
CJ_FROM_COUNTRY_CODE=CN
# Set true only on sandbox CJ accounts — adds isSandbox: 1 to createOrderV2 (default: off)
# CJ_SANDBOX_MODE=false
